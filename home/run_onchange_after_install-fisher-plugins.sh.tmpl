#!/usr/bin/env bash
set -euo pipefail

# Re-run whenever the plugin list changes.
# fish_plugins hash: {{ include "dot_config/fish/fish_plugins" | sha256sum }}

if ! command -v fish > /dev/null 2>&1; then
    echo "fish not found in PATH; skipping fisher install" >&2
    exit 0
fi

# Bootstrap fisher itself if missing, then sync plugins from fish_plugins.
fish -c 'functions -q fisher; or curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install jorgebucaran/fisher'
fish -c 'fisher update'
